{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Superadmission",
  "theme": "mint",

  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },

  "favicon": {
    "light": "/images/favicon-light.png",
    "dark": "/images/favicon-dark.png"
  },

  "colors": {
    "primary": "#000000",
    "light": "#858585",
    "dark": "#000000"
  },

  "appearance": {
    "default": "light",
    "strict": false
  },

  "icons": {
    "library": "lucide"
  },

  "search": {
    "prompt": "Search documentation..."
  },

  "navbar": {
    "primary": {
      "type": "button",
      "label": "Talk to Founders",
      "href": "https://cal.com/aashrut/talk-to-founders"
    }
  },

  "contextual": {
    "options": ["copy", "view", "assistant", "chatgpt", "claude"],
    "display": "header"
  },

  "ai": {
    "system": "You are a documentation assistant for Superadmission. Superadmission is a proposed national-scale admissions infrastructure for India. It is not yet deployed and has no official government approvals. Always reflect the proposed nature of the project. Use phrases like: designed to, proposed, intended to, if implemented, if approved. Never overstate capabilities or imply active integrations exist."
  },

  "navigation": {
    "tabs": [
      {
        "tab": "Blueprint",
        "icon": "book-open",
        "groups": [
          {
            "group": "Admissions Landscape",
            "icon": "map",
            "pages": [
              { "page": "blueprint/admissions-landscape", "icon": "landmark" },
              { "page": "blueprint/counselling-systems", "icon": "network" },
              { "page": "blueprint/admission-lifecycle", "icon": "refresh-cw" },
              { "page": "blueprint/operational-challenges", "icon": "triangle-alert" }
            ]
          },
          {
            "group": "Proposed Model",
            "icon": "layout-grid",
            "pages": [
              { "page": "blueprint/proposed-structure", "icon": "layers" },
              { "page": "blueprint/student-experience", "icon": "graduation-cap" },
              { "page": "blueprint/public-infrastructure-alignment", "icon": "link-2" }
            ]
          },
          {
            "group": "Context",
            "icon": "info",
            "pages": [
              { "page": "blueprint/standards-and-assumptions", "icon": "ruler" },
              { "page": "blueprint/implementation-context", "icon": "map-pin" },
              { "page": "blueprint/governance-and-compliance", "icon": "scale" }
