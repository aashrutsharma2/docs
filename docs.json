{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Superadmission",
  "theme": "mint",

  "logo": {
    "light": "/images/superadmission-wordmark-light(1).svg",
    "dark": "/images/superadmission-wordmark-dark.svg"
  },

  "favicon": {
    "light": "/images/favicon-light.png",
    "dark": "/images/favicon-dark.png"
  },

  "colors": {
    "primary": "#404040",
    "light": "#ebebeb",
    "dark": "#0A0A0A"
  },

  "appearance": {
    "default": "light",
    "strict": false
  },

  "fonts": {
    "heading": {
      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },

  "icons": {
    "library": "lucide"
  },

  "search": {
    "prompt": "Search documentation..."
  },

  "assistant": {
    "placeholder": "Ask anything about Superadmission...",
    "suggestions": [
      "What is Superadmission?",
      "How does PraveshAI work?",
      "What is the seat allocation system?",
      "How does identity verification work?",
      "What problem does Superadmission solve?"
    ]
  },

  "navbar": {
    "links": [
      {
        "label": "",
        "href": "https://x.com/aashruts",
        "icon": "x-twitter"
      },
      {
        "label": "",
        "href": "https://www.linkedin.com/company/superadmission/",
        "icon": "linkedin"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Talk to Founders",
      "href": "https://cal.com/aashrut/talk-to-founders"
    }
  },

  "contextual": {
    "options": ["copy", "view", "assistant", "chatgpt", "claude"],
    "display": "header"
  },

  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },

  "ai": {
    "system": "You are a documentation assistant for Superadmission. Superadmission is a proposed national-scale admissions infrastructure for India. It is not yet deployed and has no official government approvals. Always reflect the proposed nature of the project. Use phrases like: designed to, proposed, intended to, if implemented, if approved. Never overstate capabilities or imply active integrations exist."
  },

  "redirects": [
    {
      "source": "/",
      "destination": "/blueprint/admissions-landscape"
    }
  ],

  "footer": {
    "socials": {
      "x": "https://x.com/aashruts",
      "linkedin": "https://www.linkedin.com/company/superadmission/"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Blueprint", "href": "/blueprint/admissions-landscape" },
          { "label": "PraveshAI™", "href": "/praveshai/overview" },
          { "label": "Operations", "href": "/operations/authority-workflows" },
          { "label": "Changelog", "href": "/changelog/changelog" }
        ]
      },
      {
        "header": "Company",
        "items": [
          { "label": "Organisation", "href": "/organisation" },
          { "label": "Stakeholders", "href": "/stakeholders" },
          { "label": "Talk to Founders", "href": "https://cal.com/aashrut/talk-to-founders" }
        ]
      },
      {
        "header": "Connect",
        "items": [
          { "label": "X / Twitter", "href": "https://x.com/aashruts" },
          { "label": "LinkedIn", "href": "https://www.linkedin.com/company/superadmission/" }
        ]
      }
    ]
  },

  "navigation": {
    "tabs": [
      {
        "tab": "Blueprint",
        "icon": "book-open",
        "groups": [
          {
            "group": "Admissions Landscape",
            "icon": "map",
            "pages": [
              "blueprint/admissions-landscape",
              "blueprint/counselling-systems",
              "blueprint/admission-lifecycle",
              "blueprint/operational-challenges"
            ]
          },
          {
            "group": "Proposed Model",
            "icon": "layers-3",
            "pages": [
              "blueprint/proposed-structure",
              "blueprint/student-experience",
              "blueprint/public-infrastructure-alignment"
            ]
          },
          {
            "group": "Context",
            "icon": "info",
            "pages": [
              "blueprint/standards-and-assumptions",
              "blueprint/implementation-context",
              "blueprint/governance-and-compliance"
            ]
          }
        ]
      },
      {
        "tab": "PraveshAI™",
        "icon": "zap",
        "groups": [
          {
            "group": "Overview",
            "icon": "telescope",
            "pages": ["praveshai/overview"]
          },
          {
            "group": "Core Capabilities",
            "icon": "cpu",
            "pages": [
              "praveshai/identity-and-verification",
              "praveshai/document-workflows",
              "praveshai/guidance-and-support",
              "praveshai/seat-allocation"
            ]
          },
          {
            "group": "System Internals",
            "icon": "settings-2",
            "pages": [
              "praveshai/workflow-coordination",
              "praveshai/infrastructure"
            ]
          },
          {
            "group": "Trust",
            "icon": "shield",
            "pages": [
              "praveshai/safeguards-and-oversight",
              "praveshai/audit-and-explainability"
            ]
          }
        ]
      },
      {
        "tab": "Operations",
        "icon": "clipboard-list",
        "groups": [
          {
            "group": "Authority and Institution",
            "icon": "building-2",
            "pages": [
              "operations/authority-workflows",
              "operations/institution-workflows",
              "operations/verification-and-review"
            ]
          },
          {
            "group": "Monitoring and Control",
            "icon": "monitor",
            "pages": [
              "operations/reporting-and-monitoring",
              "operations/grievance-and-escalation",
              "operations/operational-controls"
            ]
          }
        ]
      },
      {
        "tab": "Stakeholders",
        "icon": "users",
        "groups": [
          {
            "group": "Overview",
            "icon": "contact",
            "pages": ["stakeholders"]
          }
        ]
      },
      {
        "tab": "Organisation",
        "icon": "briefcase",
        "groups": [
          {
            "group": "Overview",
            "icon": "badge-info",
            "pages": ["organisation"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "clock-3",
        "groups": [
          {
            "group": "Updates",
            "icon": "history",
            "pages": [
              "changelog/changelog",
              "changelog/progress",
              "changelog/validation-and-readiness",
              "changelog/known-constraints"
            ]
          }
        ]
      }
    ]
  },
  "background": {
    "image": {
      "light": "/images/BG_MINT_LIGHTMODE.png",
      "dark": "/images/BG_MINT_DARKMODE.png"
    }
  }
}