      "family": "Geist",
      "weight": 600
    },
    "body": {
      "family": "Geist",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "search": {
    "prompt": "Search Superadmission docs..."
  },
  "navbar": {
    "links": [],
