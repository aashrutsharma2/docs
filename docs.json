{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Superadmission Documentation",
  "theme": "mint",
  "logo": {
    "light": "/images/superadmission-icon-black.png",
    "dark": "/images/superadmission-icon-white.png"
  },
  "favicon": {
    "light": "/images/superadmission-icon-black.png",
    "dark": "/images/superadmission-icon-white.png"
  },
  "colors": {
    "primary": "#000000",
    "light": "#525252",
    "dark": "#000000"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "dark": "#0a0a0a",
      "light": "#ffffff"
    }
  },
  "appearance": {
